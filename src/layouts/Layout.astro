---
import { buildBasePath } from '../utils/base-path';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '行方市のオープンデータを、誰もが使える形に' } = Astro.props;
const faviconUrl = buildBasePath(import.meta.env.BASE_URL, 'favicon.svg');
const manifestUrl = buildBasePath(import.meta.env.BASE_URL, 'manifest.json');
const swUrl = buildBasePath(import.meta.env.BASE_URL, 'sw.js');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' https://*.tile.openstreetmap.org https://cyberjapandata.gsi.go.jp data:; connect-src 'self' https://*.tile.openstreetmap.org https://cyberjapandata.gsi.go.jp;" />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="alternate" type="application/rss+xml" title="NAMEGATA OPEN DATA" href={buildBasePath(import.meta.env.BASE_URL, 'rss.xml')} />
    <link rel="manifest" href={manifestUrl} />
    <slot name="head" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline define:vars={{ swUrl }}>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register(swUrl).catch(() => {});
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
