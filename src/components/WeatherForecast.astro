---
import { buildBasePath } from '../utils/base-path';

const chartJsUrl = buildBasePath(import.meta.env.BASE_URL, 'chart.min.js');
---

<section class="section weather-section">
  <div class="container">
    <div class="weather-header">
      <h2 class="weather-title">PRECIPITATION FORECAST</h2>
      <p class="weather-sub">行方市 48時間降水量予測</p>
    </div>

    <div class="weather-grid">
      <div class="card weather-card">
        <div class="weather-current" id="weather-current">
          <p class="weather-loading">データ取得中...</p>
        </div>
      </div>

      <div class="card weather-chart-card">
        <div class="weather-chart-wrap">
          <canvas id="precipitation-chart"></canvas>
        </div>
        <p class="weather-note" id="weather-note"></p>
      </div>
    </div>

    <p class="weather-attribution">
      気象データ: <a href="https://open-meteo.com/" target="_blank" rel="noopener">Open-Meteo API</a>
      (CC BY 4.0) / 観測地点: 行方市中心部 (36.08&deg;N, 140.48&deg;E)
    </p>
  </div>
</section>

<script is:inline src={chartJsUrl}></script>
<script is:inline>
  (() => {
    const LAT = 36.08;
    const LON = 140.48;
    const API_URL = `https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&hourly=precipitation,weathercode,temperature_2m,relative_humidity_2m,windspeed_10m&current_weather=true&timezone=Asia%2FTokyo&forecast_days=3`;

    const WMO_CODES = {
      0: ['快晴', '☀️'], 1: ['晴れ', '🌤'], 2: ['やや曇り', '⛅'],
      3: ['曇り', '☁️'], 45: ['霧', '🌫'], 48: ['着氷霧', '🌫'],
      51: ['弱い霧雨', '🌦'], 53: ['霧雨', '🌦'], 55: ['強い霧雨', '🌧'],
      61: ['弱い雨', '🌦'], 63: ['雨', '🌧'], 65: ['大雨', '🌧'],
      66: ['弱い着氷雨', '🌧'], 67: ['着氷雨', '🌧'],
      71: ['弱い雪', '🌨'], 73: ['雪', '🌨'], 75: ['大雪', '❄️'],
      77: ['霰', '🌨'], 80: ['弱いにわか雨', '🌦'], 81: ['にわか雨', '🌧'],
      82: ['激しいにわか雨', '⛈'], 85: ['弱いにわか雪', '🌨'],
      86: ['強いにわか雪', '❄️'], 95: ['雷雨', '⛈'],
      96: ['雹を伴う雷雨', '⛈'], 99: ['大粒の雹', '⛈'],
    };

    function getWeatherLabel(code) {
      return WMO_CODES[code] || ['不明', '❓'];
    }

    function fmtHour(iso) {
      const d = new Date(iso);
      const h = d.getHours();
      return h + '時';
    }

    function fmtDate(iso) {
      const d = new Date(iso);
      return (d.getMonth() + 1) + '/' + d.getDate();
    }

    function getRainLevel(mm) {
      if (mm === 0) return ['なし', 'var(--text-dim)'];
      if (mm < 1) return ['弱い雨', 'var(--accent-blue)'];
      if (mm < 5) return ['雨', 'var(--accent-blue)'];
      if (mm < 20) return ['やや強い雨', 'var(--accent-orange)'];
      if (mm < 50) return ['強い雨', 'var(--accent-orange)'];
      return ['非常に強い雨', '#ef4444'];
    }

    async function fetchWeather() {
      const currentEl = document.getElementById('weather-current');
      const noteEl = document.getElementById('weather-note');

      try {
        const res = await fetch(API_URL);
        if (!res.ok) throw new Error('API Error');
        const data = await res.json();

        const current = data.current_weather;
        const [weatherLabel, weatherIcon] = getWeatherLabel(current.weathercode);

        const hourly = data.hourly;
        const now = new Date();
        const startIdx = hourly.time.findIndex(t => new Date(t) >= now);
        const sliceStart = Math.max(startIdx, 0);
        const sliceEnd = Math.min(sliceStart + 48, hourly.time.length);

        const times = hourly.time.slice(sliceStart, sliceEnd);
        const precip = hourly.precipitation.slice(sliceStart, sliceEnd);
        const temps = hourly.temperature_2m.slice(sliceStart, sliceEnd);

        const total48h = precip.reduce((s, v) => s + v, 0);
        const maxPrecip = Math.max(...precip);
        const maxPrecipTime = times[precip.indexOf(maxPrecip)];
        const [rainLabel, rainColor] = getRainLevel(maxPrecip);

        currentEl.innerHTML = `
          <div class="current-main">
            <span class="current-icon">${weatherIcon}</span>
            <div class="current-info">
              <span class="current-temp">${current.temperature}°C</span>
              <span class="current-weather">${weatherLabel}</span>
            </div>
          </div>
          <div class="current-stats">
            <div>
              <span class="cs-label">48h累積</span>
              <strong style="color:${total48h > 0 ? 'var(--accent-blue)' : 'var(--text-dim)'}">${total48h.toFixed(1)} mm</strong>
            </div>
            <div>
              <span class="cs-label">最大時間雨量</span>
              <strong style="color:${rainColor}">${maxPrecip.toFixed(1)} mm</strong>
            </div>
            <div>
              <span class="cs-label">ピーク時刻</span>
              <strong>${maxPrecip > 0 ? fmtDate(maxPrecipTime) + ' ' + fmtHour(maxPrecipTime) : '-'}</strong>
            </div>
            <div>
              <span class="cs-label">風速</span>
              <strong>${current.windspeed} km/h</strong>
            </div>
          </div>
        `;

        const labels = times.map((t, i) => {
          const d = new Date(t);
          return d.getHours() === 0 || i === 0 ? fmtDate(t) + ' ' + fmtHour(t) : fmtHour(t);
        });

        const barColors = precip.map(v => {
          if (v === 0) return 'rgba(59, 130, 246, 0.15)';
          if (v < 1) return 'rgba(59, 130, 246, 0.5)';
          if (v < 5) return 'rgba(59, 130, 246, 0.75)';
          if (v < 20) return 'rgba(249, 115, 22, 0.75)';
          return 'rgba(239, 68, 68, 0.85)';
        });

        if (typeof Chart !== 'undefined') {
          const ctx = document.getElementById('precipitation-chart');
          if (ctx) {
            new Chart(ctx, {
              type: 'bar',
              data: {
                labels: labels,
                datasets: [
                  {
                    label: '降水量 (mm)',
                    data: precip,
                    backgroundColor: barColors,
                    borderWidth: 0,
                    borderRadius: 2,
                    yAxisID: 'y',
                    order: 2,
                  },
                  {
                    label: '気温 (°C)',
                    data: temps,
                    type: 'line',
                    borderColor: 'rgba(249, 115, 22, 0.8)',
                    backgroundColor: 'transparent',
                    borderWidth: 1.5,
                    pointRadius: 0,
                    tension: 0.3,
                    yAxisID: 'y1',
                    order: 1,
                  },
                ],
              },
              options: {
                responsive: true,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                  legend: {
                    display: true,
                    position: 'bottom',
                    labels: {
                      boxWidth: 10,
                      padding: 8,
                      font: { size: 10, family: 'JetBrains Mono, monospace' },
                      color: '#9898a8',
                    },
                  },
                },
                scales: {
                  x: {
                    grid: { display: false },
                    ticks: {
                      maxRotation: 0,
                      autoSkip: true,
                      maxTicksLimit: 12,
                      font: { size: 9 },
                    },
                  },
                  y: {
                    beginAtZero: true,
                    position: 'left',
                    title: { display: true, text: 'mm', font: { size: 9 }, color: '#5a5a6e' },
                    grid: { color: '#1e1e2e' },
                    ticks: { font: { size: 9 } },
                  },
                  y1: {
                    position: 'right',
                    title: { display: true, text: '°C', font: { size: 9 }, color: '#5a5a6e' },
                    grid: { display: false },
                    ticks: { font: { size: 9 } },
                  },
                },
              },
            });
          }
        }

        const updateTime = new Date().toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' });
        noteEl.textContent = `最終取得: ${updateTime} / 予測は参考情報です。防災判断は気象庁の公式情報を確認してください。`;

      } catch (e) {
        currentEl.innerHTML = '<p class="weather-error">気象データの取得に失敗しました。再読み込みしてください。</p>';
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fetchWeather);
    } else {
      fetchWeather();
    }
  })();
</script>

<style>
  .weather-section {
    padding: 3rem 0;
  }

  .weather-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .weather-title {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--accent-blue);
  }

  .weather-sub {
    color: var(--text-secondary);
    font-size: 0.82rem;
    margin-top: 0.3rem;
  }

  .weather-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1rem;
    align-items: start;
  }

  .weather-card {
    padding: 1.2rem;
  }

  .weather-loading, .weather-error {
    color: var(--text-dim);
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .weather-error {
    color: var(--accent-orange);
  }

  :global(.current-main) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  :global(.current-icon) {
    font-size: 2.2rem;
  }

  :global(.current-info) {
    display: flex;
    flex-direction: column;
  }

  :global(.current-temp) {
    font-family: var(--font-mono);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  :global(.current-weather) {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  :global(.current-stats) {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  :global(.current-stats div) {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  :global(.cs-label) {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: var(--text-dim);
  }

  :global(.current-stats strong) {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-primary);
  }

  .weather-chart-card {
    padding: 1rem;
  }

  .weather-chart-wrap {
    position: relative;
    width: 100%;
    max-height: 280px;
  }

  .weather-note {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
  }

  .weather-attribution {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    text-align: center;
  }

  .weather-attribution a {
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .weather-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
